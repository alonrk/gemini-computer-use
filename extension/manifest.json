{
  "manifest_version": 3,
  "name": "Gemini Computer Use",
  "description": "Run Gemini-guided browser tasks against the current tab through a local helper service.",
  "version": "0.1.0",
  "permissions": ["activeTab", "scripting", "sidePanel", "storage", "tabs"],
  "host_permissions": ["<all_urls>", "http://127.0.0.1:3210/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Gemini Computer Use"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-script.js"],
      "run_at": "document_idle"
    }
  ]
}
